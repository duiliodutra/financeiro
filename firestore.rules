rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedUser() {
      return request.auth != null && (
        request.auth.token.email == 'duiliodudu@gmail.com' ||
        request.auth.token.email == 'deysinhalmeida@gmail.com'
      );
    }

    function sharedUserId() {
      return 'financeiro-deyse';
    }

    function isOwner() {
      return isAllowedUser() && resource.data.userId == sharedUserId();
    }

    function isOwnerOnCreate() {
      return isAllowedUser() && request.resource.data.userId == sharedUserId();
    }

    match /blocks/{blockId} {
      allow read, update, delete: if isOwner();
      allow create: if isOwnerOnCreate();
    }

    match /entries/{entryId} {
      allow read, update, delete: if isOwner();
      allow create: if isOwnerOnCreate();
    }

    match /forecasts/{forecastId} {
      allow read, update, delete: if isOwner();
      allow create: if isOwnerOnCreate();
    }

    match /usuarios/{userId}/{document=**} {
      allow read, write: if isAllowedUser() && request.auth.uid == userId;
    }
  }
}
